# AI Model Provider
# Supported: "openai", "gemini", or any OpenAI-compatible provider
MODEL_PROVIDER=gemini
MODEL_NAME=gemini-2.5-flash

# Google Gemini (get key from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI (alternative provider)
OPENAI_API_KEY=
# Custom base URL for Ollama or other OpenAI-compatible providers
OPENAI_BASE_URL=

# JWT Authentication
JWT_SECRET=change-me-in-production

# Application
DEBUG=false

# Database
DATABASE_PATH=data/app.db

# Data Paths
DATA_DIR=data
PDF_STORAGE_DIR=data/pdfs
CSV_STORAGE_DIR=data/csv

# ChromaDB
CHROMA_PERSIST_DIR=data/chroma
